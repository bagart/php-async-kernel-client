{
    "name": "bagart/ask-client",
    "description": "Async network client and HTTP transport layer for the ASK runtime",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ASK",
        "network",
        "http",
        "client",
        "transport",
        "curl",
        "guzzle",
        "async",
        "fiber",
        "queue",
        "job",
        "partition"
    ],
    "authors": [
        {
            "name": "BAGArt (Artur Baltaev)",
            "email": "baltaev.artur+ask@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "bagart/async-kernel": "*",
        "psr/http-message": "^1.0|^2.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "BAGArt\\ASKClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BAGArt\\ASKClient\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
